@{
    Layout = "_Layout";
    ViewData["Title"] = "Thanh Toán";
}

<style>
    .payment-option {
        display: block;
        border: 1px solid #e1e1e1;
        border-radius: 6px;
        padding: 10px 12px;
        margin-bottom: 10px;
        cursor: pointer;
        transition: all .2s;
    }

    .payment-option.active {
        border-color: #7fad39;
        background: #f6fff0;
    }

    .payment-option .payment-label {
        font-weight: 600;
    }
</style>

<section class="breadcrumb-section set-bg" data-setbg="/img/breadcrumb.jpg">
    <div class="container">
        <div class="row">
            <div class="col-lg-12 text-center">
                <div class="breadcrumb__text">
                    <h2>Thanh Toán</h2>
                    <div class="breadcrumb__option">
                        <a href="/">Trang Chủ</a>
                        <span>Thanh Toán</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="checkout spad">
    <div class="container">
        <div class="checkout__form">
            <h4>Thông Tin Thanh Toán</h4>
            <form id="checkout-form">
                <div class="row">
                    <div class="col-lg-8 col-md-6">
                        <div class="checkout__input">
                            <p>Họ và Tên<span>*</span></p>
                            <input type="text" id="order-name" placeholder="Nhập đầy đủ họ tên người nhận" required>
                        </div>
                        <div class="checkout__input">
                            <p>Địa Chỉ Nhận Hàng<span>*</span></p>
                            <input type="text" id="order-address" placeholder="Số nhà, tên đường, xã/phường..." required>
                        </div>
                        <div class="row">
                            <div class="col-lg-6">
                                <div class="checkout__input">
                                    <p>Điện Thoại<span>*</span></p>
                                    <input type="text" id="order-phone" required>
                                </div>
                            </div>
                            <div class="col-lg-6">
                                <div class="checkout__input">
                                    <p>Email</p>
                                    <input type="email" id="order-email">
                                </div>
                            </div>
                        </div>
                        <div class="checkout__input">
                            <p>Ghi Chú Đơn Hàng</p>
                            <input type="text" id="order-note" placeholder="Ví dụ: Giao giờ hành chính">
                        </div>
                    </div>
                    <div class="col-lg-4 col-md-6">
                        <div class="checkout__order">
                            <h4>Đơn Hàng Của Bạn</h4>
                            <div class="checkout__order__products">Sản Phẩm <span>Tổng Cộng</span></div>
                            <ul id="checkout-list">
                            </ul>
                            <div style="margin-bottom: 12px;">
                                <div class="input-group">
                                    <input type="text" id="voucher-code" class="form-control" placeholder="Nhập mã giảm giá">
                                    <div class="input-group-append">
                                        <button type="button" id="btn-apply-voucher" class="btn btn-outline-success">Áp dụng</button>
                                    </div>
                                </div>
                                <small id="voucher-message" style="display:block; margin-top:6px;"></small>
                            </div>
                            <div class="checkout__order__subtotal">Tạm Tính <span id="checkout-subtotal">0đ</span></div>
                            <div class="checkout__order__subtotal">Giảm giá <span id="checkout-discount">0đ</span></div>
                            <div class="checkout__order__total">Tổng Cộng <span id="checkout-total" style="color: #dd2222; font-weight: bold; font-size: 20px;">0đ</span></div>

                            <div class="checkout__input__checkbox" style="margin-bottom: 10px;">
                                <label class="payment-option active">
                                    <input type="radio" name="payment-method" value="COD" checked>
                                    <span class="checkmark"></span>
                                    <span class="payment-label">Thanh toán khi nhận hàng (COD)</span>
                                </label>
                            </div>
                            <div class="checkout__input__checkbox" style="margin-bottom: 15px;">
                                <label class="payment-option">
                                    <input type="radio" name="payment-method" value="VNPAY">
                                    <span class="checkmark"></span>
                                    <span class="payment-label">Thanh toán VNPay</span>
                                </label>
                            </div>

                            <button type="button" id="btn-place-order" class="site-btn">ĐẶT HÀNG NGAY</button>
                        </div>
                    </div>
                </div>
            </form>
        </div>
    </div>
</section>

@section Scripts {
    <script src="/js/checkout-logic.js"></script>
}