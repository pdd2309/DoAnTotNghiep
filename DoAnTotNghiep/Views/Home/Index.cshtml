@using DoAnTotNghiep.Models

@{
    // Kết nối với khung Layout chung
    ViewData["Title"] = "Trang Chủ";
    Layout = "~/Views/Shared/_Layout.cshtml";

    var heroBanner = ViewBag.HeroBanner as Banner;
    var bottomBanners = ViewBag.BottomBanners as List<Banner> ?? new List<Banner>();
}

<section class="hero">
    <div class="container">
        <div class="row">
            <div class="col-lg-3">
                <div class="hero__categories">
                    <div class="hero__categories__all">
                        <i class="fa fa-bars"></i>
                        <span>Tất cả danh mục</span>
                    </div>
                    @* Danh mục này sẽ được categories.js đổ dữ liệu vào *@
                    <ul id="category-list-index">
                        <li><a href="#">Đang tải danh mục...</a></li>
                    </ul>
                </div>
            </div>
            <div class="col-lg-9">
                <div class="hero__search">
                    <div class="hero__search__form">
                        @* --- FIX LỖI TÌM KIẾM TẠI ĐÂY --- *@
                        <form action="/Home/Shop" method="get">
                            <div class="hero__search__categories">
                                Tất cả Danh Mục
                                <span class="arrow_carrot-down"></span>
                            </div>
                            @* Ô nhập liệu quan trọng nhất là name="searchString" *@
                            <input type="text" name="searchString" placeholder="Bạn cần tìm gì?">
                            <button type="submit" class="site-btn">TÌM KIẾM</button>
                        </form>
                    </div>
                    <div class="hero__search__phone">
                        <div class="hero__search__phone__icon">
                            <i class="fa fa-phone"></i>
                        </div>
                        <div class="hero__search__phone__text">
                            <h5>+84 123 456 789</h5>
                            <span>Hỗ trợ 24/7</span>
                        </div>
                    </div>
                </div>

                @* Banner quảng cáo chính của trang chủ (từ DB) *@
                @if (heroBanner != null)
                {
                    var heroImage = string.IsNullOrWhiteSpace(heroBanner.ImageUrl) ? "/img/hero/banner.jpg" : heroBanner.ImageUrl;
                    var heroLink = string.IsNullOrWhiteSpace(heroBanner.LinkUrl) ? "/Home/Shop" : heroBanner.LinkUrl;

                    <div class="hero__item set-bg" data-setbg="@heroImage" style="background-image: url('@heroImage');">
                        <div class="hero__text">
                            <span>@(heroBanner.SubTitle ?? "CÔNG NGHỆ MỚI")</span>
                            <h2>@(heroBanner.Title ?? "Sản Phẩm")</h2>
                            <p>@(heroBanner.Description ?? "Giao hàng nhanh - Hàng Chính Hãng 100%")</p>
                            <a href="@heroLink" class="primary-btn">MUA NGAY</a>
                        </div>
                    </div>
                }
                else
                {
                    <div class="hero__item set-bg" data-setbg="/img/hero/banner.jpg" style="background-image: url('/img/hero/banner.jpg');">
                        <div class="hero__text">
                            <span>CÔNG NGHỆ MỚI</span>
                            <h2>Sản Phẩm <br />Chất Lượng Cao</h2>
                            <p>Giao hàng nhanh - Hàng Chính Hãng 100%</p>
                            <a href="/Home/Shop" class="primary-btn">MUA NGAY</a>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
</section>

<section class="categories">
    <div class="container">
        <div class="row">
            <div class="categories__slider owl-carousel" id="category-slider-list">
                @* JS sẽ tự đổ dữ liệu vào đây *@
            </div>
        </div>
    </div>
</section>

<section class="featured spad">
    <div class="container">
        <div class="row">
            <div class="col-lg-12">
                <div class="section-title">
                    <h2>Sản Phẩm Nổi Bật</h2>
                </div>
                <div class="featured__controls">
                    <ul>
                        <li class="active" data-filter="*">Tất Cả</li>
                    </ul>
                </div>
            </div>
        </div>
        @* ID product-list để fetch-products.js đổ sản phẩm vào *@
        <div class="row featured__filter" id="product-list">
            <div class="col-12 text-center">
                <p>Đang tải sản phẩm nổi bật...</p>
            </div>
        </div>
    </div>
</section>

<div class="banner">
    <div class="container">
        <div class="row">
            @if (bottomBanners.Any())
            {
                foreach (var banner in bottomBanners)
                {
                    var imageUrl = string.IsNullOrWhiteSpace(banner.ImageUrl) ? "/img/banner/banner-1.jpg" : banner.ImageUrl;
                    var linkUrl = string.IsNullOrWhiteSpace(banner.LinkUrl) ? "/Home/Shop" : banner.LinkUrl;

                    <div class="col-lg-6 col-md-6 col-sm-6">
                        <div class="banner__pic">
                            <a href="@linkUrl">
                                <img src="@imageUrl" alt="@(banner.Title ?? "Banner")">
                            </a>
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="col-lg-6 col-md-6 col-sm-6">
                    <div class="banner__pic">
                        <img src="/img/banner/banner-1.jpg" alt="Banner 1">
                    </div>
                </div>
                <div class="col-lg-6 col-md-6 col-sm-6">
                    <div class="banner__pic">
                        <img src="/img/banner/banner-2.jpg" alt="Banner 2">
                    </div>
                </div>
            }
        </div>
    </div>
</div>

@section Scripts {
    @* Đông nhớ kiểm tra 2 file JS này phải nằm đúng trong thư mục wwwroot/js nhé *@
    <script src="/js/fetch-products.js"></script>
    <script src="/js/categories.js"></script>
}