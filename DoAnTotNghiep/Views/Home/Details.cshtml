@{
    Layout = "_Layout";
    ViewData["Title"] = "Chi Tiết Sản Phẩm";
}

<section class="breadcrumb-section set-bg" data-setbg="/img/breadcrumb.jpg">
    <div class="container">
        <div class="row">
            <div class="col-lg-12 text-center">
                <div class="breadcrumb__text">
                    <h2 id="detail-name-top">Chi tiết sản phẩm</h2>
                    <div class="breadcrumb__option">
                        <a href="/">Trang Chủ</a>
                        <a href="/Home/Shop">Cửa Hàng</a>
                        <span id="breadcrumb-name">Đang tải...</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="product-details spad">
    <div class="container">
        <div class="row" id="product-detail-content">
            <div class="col-12 text-center"><h3>Đang tải thông tin sản phẩm...</h3></div>
        </div>

        <div class="row mt-5">
            <div class="col-lg-12">
                <div class="product__details__tab">
                    <ul class="nav nav-tabs">
                        <li class="nav-item">
                            <a class="nav-link active">Đánh giá <span id="review-count">(0)</span></a>
                        </li>
                    </ul>
                    <div class="tab-content pt-4">
                        <div id="review-list" class="mb-5">
                            <p class="text-center">Đang tải bình luận...</p>
                        </div>

                        <hr class="my-5" />

                        <div class="contact-form spad" style="padding-top: 0;">
                            <div class="section-title">
                                <h2 style="font-size: 24px; text-align: left;">Để lại đánh giá của bạn</h2>
                            </div>
                            <div class="row">
                                <div class="col-lg-12">
                                    <textarea id="review-content" placeholder="Sản phẩm này dùng tốt không ông ơi?" style="width: 100%; height: 100px; padding: 15px; border: 1px solid #ebebeb; margin-bottom: 20px;"></textarea>
                                    <div class="d-flex align-items-center mb-4">
                                        <span class="mr-3">Chọn số sao: </span>
                                        <select id="review-stars" class="form-control" style="width: 120px;">
                                            <option value="5">5 Sao ★</option>
                                            <option value="4">4 Sao ★</option>
                                            <option value="3">3 Sao ★</option>
                                            <option value="2">2 Sao ★</option>
                                            <option value="1">1 Sao ★</option>
                                        </select>
                                    </div>
                                    <button type="button" onclick="sendReview()" class="site-btn">GỬI ĐÁNH GIÁ</button>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <script>
        const productId = '@ViewBag.MaSanPham';
    </script>
    <script src="/js/fetch-detail.js"></script>
}