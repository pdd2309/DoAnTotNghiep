@{
    ViewData["Title"] = "Bảng điều khiển Admin";
}

<div class="d-sm-flex align-items-center justify-content-between mb-4">
    <h1 class="h3 mb-0 text-gray-800 lang"
        data-vi="Bảng điều khiển hệ thống"
        data-en="System Dashboard">
        Bảng điều khiển hệ thống
    </h1>
    <a href="#" class="d-none d-sm-inline-block btn btn-sm btn-primary shadow-sm">
        <i class="fas fa-download fa-sm text-white-50"></i>
        <span class="lang" data-vi="Tạo báo cáo" data-en="Generate Report">Tạo báo cáo</span>
    </a>
</div>

<div class="row">
    <div class="col-xl-3 col-md-6 mb-4">
        <div class="card border-left-primary shadow h-100 py-2">
            <div class="card-body">
                <div class="row no-gutters align-items-center">
                    <div class="col mr-2">
                        <div class="text-xs font-weight-bold text-primary text-uppercase mb-1 lang"
                             data-vi="Tổng sản phẩm" data-en="Total Products">
                            Tổng sản phẩm
                        </div>
                        <div class="h5 mb-0 font-weight-bold text-gray-800">120</div>
                    </div>
                    <div class="col-auto">
                        <i class="fas fa-laptop fa-2x text-gray-300"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-xl-3 col-md-6 mb-4">
        <div class="card border-left-success shadow h-100 py-2">
            <div class="card-body">
                <div class="row no-gutters align-items-center">
                    <div class="col mr-2">
                        <div class="text-xs font-weight-bold text-success text-uppercase mb-1 lang"
                             data-vi="Đơn hàng mới" data-en="New Orders">
                            Đơn hàng mới
                        </div>
                        <div class="h5 mb-0 font-weight-bold text-gray-800">25</div>
                    </div>
                    <div class="col-auto">
                        <i class="fas fa-shopping-cart fa-2x text-gray-300"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-lg-12">
        <div class="card shadow mb-4">
            <div class="card-header py-3">
                <h6 class="m-0 font-weight-bold text-primary lang"
                    data-vi="Thông báo hệ thống" data-en="System Notifications">
                    Thông báo hệ thống
                </h6>
            </div>
            <div class="card-body">
                <p class="lang"
                   data-vi="Chào mừng Đông quay trở lại trang quản trị Tech Store. Hãy kiểm tra các đơn hàng mới trong ngày hôm nay nhé!"
                   data-en="Welcome back to Tech Store Admin. Please check the new orders for today!">
                    Chào mừng Đông quay trở lại trang quản trị Tech Store. Hãy kiểm tra các đơn hàng mới trong ngày hôm nay nhé!
                </p>
            </div>
        </div>
    </div>
</div>