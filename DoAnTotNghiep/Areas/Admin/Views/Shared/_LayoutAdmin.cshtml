<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
    <title>@ViewData["Title"] - Admin Tech Store</title>

    <link href="/admin/vendor/fontawesome-free/css/all.min.css" rel="stylesheet" type="text/css">
    <link href="https://fonts.googleapis.com/css?family=Nunito:200,200i,300,300i,400,400i,600,600i,700,700i,800,800i,900,900i" rel="stylesheet">

    <link href="/admin/css/sb-admin-2.min.css" rel="stylesheet">

    <link href="/admin/vendor/datatables/dataTables.bootstrap4.min.css" rel="stylesheet">

    <style>
        .sidebar-brand-text {
            text-transform: uppercase;
            font-weight: bold;
        }

        .bg-gradient-primary {
            background-color: #007bff;
            background-image: linear-gradient(180deg,#007bff 10%,#0056b3 100%);
        }
    </style>
</head>

<body id="page-top">
    <div id="wrapper">
        <ul class="navbar-nav bg-gradient-primary sidebar sidebar-dark accordion" id="accordionSidebar">
            <a class="sidebar-brand d-flex align-items-center justify-content-center" href="/Admin/Home">
                <div class="sidebar-brand-icon rotate-n-15">
                    <i class="fas fa-laptop-code"></i>
                </div>
                <div class="sidebar-brand-text mx-3">Tech Admin</div>
            </a>
            <hr class="sidebar-divider my-0">

            <li class="nav-item">
                <a class="nav-link" href="/Admin/Home">
                    <i class="fas fa-fw fa-tachometer-alt"></i>
                    <span class="lang" data-vi="Bảng điều khiển" data-en="Dashboard">Bảng điều khiển</span>
                </a>
            </li>

            <hr class="sidebar-divider">
            <div class="sidebar-heading">Quản lý hệ thống</div>

            <li class="nav-item">
                <a class="nav-link" href="/Admin/DanhMucs">
                    <i class="fas fa-fw fa-folder"></i>
                    <span class="lang" data-vi="Danh mục sản phẩm" data-en="Categories">Danh mục sản phẩm</span>
                </a>
            </li>

            <li class="nav-item">
                <a class="nav-link" href="/Admin/SanPhams">
                    <i class="fas fa-fw fa-laptop"></i>
                    <span class="lang" data-vi="Danh sách sản phẩm" data-en="Product List">Danh sách sản phẩm</span>
                </a>
            </li>

            <li class="nav-item">
                <a class="nav-link" href="/Admin/DonHangs">
                    <i class="fas fa-fw fa-shopping-cart"></i>
                    <span class="lang" data-vi="Quản lý đơn hàng" data-en="Orders">Quản lý đơn hàng</span>
                </a>
            </li>

            <hr class="sidebar-divider d-none d-md-block">
            <div class="text-center d-none d-md-inline">
                <button class="rounded-circle border-0" id="sidebarToggle"></button>
            </div>
        </ul>

        <div id="content-wrapper" class="d-flex flex-column">
            <div id="content">
                <nav class="navbar navbar-expand navbar-light bg-white topbar mb-4 static-top shadow">
                    <button id="sidebarToggleTop" class="btn btn-link d-md-none rounded-circle mr-3">
                        <i class="fa fa-bars"></i>
                    </button>

                    <ul class="navbar-nav ml-auto">
                        <li class="nav-item d-flex align-items-center mr-3">
                            <button onclick="changeLang('vi')" class="btn btn-sm btn-outline-primary mr-1">VN 🇻🇳</button>
                            <button onclick="changeLang('en')" class="btn btn-sm btn-outline-secondary">EN 🇺🇸</button>
                        </li>

                        <div class="topbar-divider d-none d-sm-block"></div>

                        <li class="nav-item dropdown no-arrow">
                            <a class="nav-link dropdown-toggle" href="#" id="userDropdown" role="button" data-toggle="dropdown">
                                <span class="mr-2 d-none d-lg-inline text-gray-600 small">Admin @User.Identity.Name</span>
                                <img class="img-profile rounded-circle" src="/admin/img/undraw_profile.svg">
                            </a>
                        </li>
                    </ul>
                </nav>

                <div class="container-fluid">
                    @RenderBody()
                </div>
            </div>

            <footer class="sticky-footer bg-white">
                <div class="container my-auto">
                    <div class="copyright text-center my-auto">
                        <span>Copyright &copy; Tech Store 2026</span>
                    </div>
                </div>
            </footer>
        </div>
    </div>

    <script src="/admin/vendor/jquery/jquery.min.js"></script>
    <script src="/admin/vendor/bootstrap/js/bootstrap.bundle.min.js"></script>
    <script src="/admin/vendor/jquery-easing/jquery.easing.min.js"></script>
    <script src="/admin/js/sb-admin-2.min.js"></script>

    <script src="/admin/vendor/datatables/jquery.dataTables.min.js"></script>
    <script src="/admin/vendor/datatables/dataTables.bootstrap4.min.js"></script>

    <script>
        function changeLang(lang) {
            const elements = document.querySelectorAll('.lang');
            elements.forEach(el => {
                const text = el.getAttribute('data-' + lang);
                if (text) el.innerText = text;
            });
            localStorage.setItem('adminLang', lang);
        }
        document.addEventListener('DOMContentLoaded', () => {
            const savedLang = localStorage.getItem('adminLang') || 'vi';
            changeLang(savedLang);
        });
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>