@{
    ViewData["Title"] = "Qu\u1EA3n l\u00FD \u0111\u01A1n h\u00E0ng";
}

<div class="card shadow mb-4">
    <div class="card-header py-3 d-flex justify-content-between align-items-center">
        <h6 class="m-0 font-weight-bold text-primary">Danh s&#225;ch &#273;&#417;n h&#224;ng (API)</h6>
    </div>
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-bordered" id="orderTable" width="100%" cellspacing="0">
                <thead>
                    <tr>
                        <th>M&#227; &#273;&#417;n</th>
                        <th>Kh&#225;ch h&#224;ng</th>
                        <th>Ng&#224;y &#273;&#7863;t</th>
                        <th>T&#7893;ng ti&#7873;n</th>
                        <th>Tr&#7841;ng th&#225;i</th>
                        <th>C&#7853;p nh&#7853;t tr&#7841;ng th&#225;i</th>
                        <th>Thao t&#225;c</th>
                    </tr>
                </thead>
                <tbody></tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const ORDER_STATUSES = [
            'Ch\u1EDD x\u1EED l\u00FD',
            '\u0110ang giao',
            '\u0110\u00E3 giao h\u00E0ng',
            '\u0110\u00E3 h\u1EE7y',
            '\u0110\u00E3 thanh to\u00E1n'
        ];

        function money(v) {
            return Number(v || 0).toLocaleString('vi-VN') + ' \u0111';
        }

        function badge(status) {
            switch (status) {
                case 'Ch\u1EDD x\u1EED l\u00FD': return 'badge badge-warning';
                case '\u0110ang giao': return 'badge badge-info';
                case '\u0110\u00E3 giao h\u00E0ng': return 'badge badge-success';
                case '\u0110\u00E3 h\u1EE7y': return 'badge badge-danger';
                case '\u0110\u00E3 thanh to\u00E1n': return 'badge badge-primary';
                default: return 'badge badge-secondary';
            }
        }

        async function loadOrders() {
            const res = await fetch('/api/admin/orders');
            if (!res.ok) throw new Error('Kh\u00F4ng t\u1EA3i \u0111\u01B0\u1EE3c \u0111\u01A1n h\u00E0ng');
            return await res.json();
        }

        async function updateStatus(id) {
            const select = document.getElementById(`status-${id}`);
            if (!select) return;

            const res = await fetch(`/api/admin/orders/${id}/status`, {
                method: 'PUT',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ trangThai: select.value })
            });

            if (!res.ok) {
                alert('C\u1EADp nh\u1EADt tr\u1EA1ng th\u00E1i th\u1EA5t b\u1EA1i.');
                return;
            }

            location.reload();
        }

        $(async function () {
            try {
                const orders = await loadOrders();

                $('#orderTable').DataTable({
                    data: orders,
                    pageLength: 10,
                    order: [[0, 'desc']],
                    columns: [
                        { data: 'maDonHang', render: d => `#${d}` },
                        {
                            data: null,
                            render: function (d, t, row) {
                                return row.hoTen || row.tenDangNhap || 'N/A';
                            }
                        },
                        {
                            data: 'ngayDat',
                            render: function (d) {
                                if (!d) return '';
                                const dt = new Date(d);
                                return dt.toLocaleString('vi-VN');
                            }
                        },
                        { data: 'tongTien', render: d => money(d) },
                        {
                            data: 'trangThai',
                            render: function (d) {
                                return `<span class="${badge(d)}">${d || ''}</span>`;
                            }
                        },
                        {
                            data: null,
                            orderable: false,
                            render: function (d, t, row) {
                                const options = ORDER_STATUSES.map(s => `<option value="${s}" ${row.trangThai === s ? 'selected' : ''}>${s}</option>`).join('');
                                return `
                                    <div class="d-flex" style="min-width:220px;">
                                        <select id="status-${row.maDonHang}" class="form-control form-control-sm mr-2">${options}</select>
                                        <button class="btn btn-primary btn-sm" onclick="updateStatus(${row.maDonHang})">L\u01B0u</button>
                                    </div>
                                `;
                            }
                        },
                        {
                            data: null,
                            orderable: false,
                            render: function (d, t, row) {
                                return `<a href="/Admin/DonHangs/Details/${row.maDonHang}" class="btn btn-info btn-sm"><i class="fas fa-eye"></i></a>`;
                            }
                        }
                    ],
                    language: {
                        search: 'T\u00ECm ki\u1EBFm:',
                        lengthMenu: 'Hi\u1EC3n th\u1ECB _MENU_ d\u00F2ng',
                        info: 'Hi\u1EC3n th\u1ECB _START_ \u0111\u1EBFn _END_ c\u1EE7a _TOTAL_ \u0111\u01A1n h\u00E0ng',
                        infoEmpty: 'Kh\u00F4ng c\u00F3 d\u1EEF li\u1EC7u',
                        zeroRecords: 'Kh\u00F4ng t\u00ECm th\u1EA5y \u0111\u01A1n h\u00E0ng',
                        paginate: {
                            first: '\u0110\u1EA7u',
                            last: 'Cu\u1ED1i',
                            next: 'Sau',
                            previous: 'Tr\u01B0\u1EDBc'
                        }
                    }
                });
            } catch (e) {
                console.error(e);
                alert('Kh\u00F4ng th\u1EC3 t\u1EA3i \u0111\u01A1n h\u00E0ng t\u1EEB API admin.');
            }
        });
    </script>
}
