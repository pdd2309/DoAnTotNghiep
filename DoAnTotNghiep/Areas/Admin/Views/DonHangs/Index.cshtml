@model IEnumerable<DoAnTotNghiep.Models.DonHang>

@{
    ViewData["Title"] = "Qu\u1EA3n l\u00FD \u0111\u01A1n h\u00E0ng";

    var statusChoXuLy = "Ch\u1EDD x\u1EED l\u00FD";
    var statusDangGiao = "\u0110ang giao";
    var statusDaGiao = "\u0110\u00E3 giao h\u00E0ng";
    var statusDaHuy = "\u0110\u00E3 h\u1EE7y";

    string GetBadgeClass(string? status)
    {
        return status switch
        {
            var s when s == statusChoXuLy => "badge badge-warning",
            var s when s == statusDangGiao => "badge badge-info",
            var s when s == statusDaGiao => "badge badge-success",
            var s when s == statusDaHuy => "badge badge-danger",
            _ => "badge badge-secondary"
        };
    }
}

<div class="card shadow mb-4">
    <div class="card-header py-3 d-flex justify-content-between align-items-center">
        <h6 class="m-0 font-weight-bold text-primary">Danh s&#225;ch &#273;&#417;n h&#224;ng</h6>
    </div>
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-bordered" id="orderTable" width="100%" cellspacing="0">
                <thead>
                    <tr>
                        <th>M&#227; &#273;&#417;n</th>
                        <th>Kh&#225;ch h&#224;ng</th>
                        <th>Ng&#224;y &#273;&#7863;t</th>
                        <th>T&#7893;ng ti&#7873;n</th>
                        <th>Tr&#7841;ng th&#225;i</th>
                        <th>C&#7853;p nh&#7853;t tr&#7841;ng th&#225;i</th>
                        <th>Thao t&#225;c</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        var customerName = !string.IsNullOrWhiteSpace(item.HoTen)
                            ? item.HoTen
                            : (item.MaNguoiDungNavigation?.HoTen ?? item.MaNguoiDungNavigation?.TenDangNhap ?? "N/A");

                        <tr>
                            <td>#@item.MaDonHang</td>
                            <td>@customerName</td>
                            <td>@(item.NgayDat?.ToString("dd/MM/yyyy HH:mm") ?? "")</td>
                            <td>@((item.TongTien ?? 0).ToString("N0")) &#273;</td>
                            <td>
                                <span class="@GetBadgeClass(item.TrangThai)">@item.TrangThai</span>
                            </td>
                            <td style="min-width: 220px;">
                                <form asp-area="Admin" asp-controller="DonHangs" asp-action="UpdateStatus" method="post" class="d-flex">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@item.MaDonHang" />
                                    <select name="trangThai" class="form-control form-control-sm mr-2">
                                        <option value="@statusChoXuLy" selected="@(item.TrangThai == statusChoXuLy)">@statusChoXuLy</option>
                                        <option value="@statusDangGiao" selected="@(item.TrangThai == statusDangGiao)">@statusDangGiao</option>
                                        <option value="@statusDaGiao" selected="@(item.TrangThai == statusDaGiao)">@statusDaGiao</option>
                                        <option value="@statusDaHuy" selected="@(item.TrangThai == statusDaHuy)">@statusDaHuy</option>
                                    </select>
                                    <button type="submit" class="btn btn-primary btn-sm">L&#432;u</button>
                                </form>
                            </td>
                            <td>
                                <a asp-area="Admin" asp-controller="DonHangs" asp-action="Details" asp-route-id="@item.MaDonHang" class="btn btn-info btn-sm">
                                    <i class="fas fa-eye"></i>
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(function () {
            $('#orderTable').DataTable({
                pageLength: 10,
                order: [[0, 'desc']],
                columnDefs: [
                    { orderable: false, targets: [5, 6] }
                ],
                language: {
                    search: 'T\u00ECm ki\u1EBFm:',
                    lengthMenu: 'Hi\u1EC3n th\u1ECB _MENU_ d\u00F2ng',
                    info: 'Hi\u1EC3n th\u1ECB _START_ \u0111\u1EBFn _END_ c\u1EE7a _TOTAL_ \u0111\u01A1n h\u00E0ng',
                    infoEmpty: 'Kh\u00F4ng c\u00F3 d\u1EEF li\u1EC7u',
                    zeroRecords: 'Kh\u00F4ng t\u00ECm th\u1EA5y \u0111\u01A1n h\u00E0ng',
                    paginate: {
                        first: '\u0110\u1EA7u',
                        last: 'Cu\u1ED1i',
                        next: 'Sau',
                        previous: 'Tr\u01B0\u1EDBc'
                    }
                }
            });
        });
    </script>
}
