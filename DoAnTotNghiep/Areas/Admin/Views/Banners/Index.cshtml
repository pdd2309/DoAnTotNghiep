@{
    ViewData["Title"] = "Qu\u1EA3n l\u00FD banner";
}

<div class="card shadow mb-4">
    <div class="card-header py-3 d-flex justify-content-between align-items-center">
        <h6 class="m-0 font-weight-bold text-primary">Qu&#7843;n l&#253; banner trang ch&#7911; (API)</h6>
        <button class="btn btn-primary btn-sm" onclick="openCreateModal()">Th&#234;m banner</button>
    </div>
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-bordered" id="bannerTable" width="100%">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>V&#7883; tr&#237;</th>
                        <th>Ti&#234;u &#273;&#7873;</th>
                        <th>H&#236;nh &#7843;nh</th>
                        <th>Th&#7913; t&#7921;</th>
                        <th>Hi&#7875;n th&#7883;</th>
                        <th>Thao t&#225;c</th>
                    </tr>
                </thead>
                <tbody></tbody>
            </table>
        </div>
    </div>
</div>

<div class="modal fade" id="bannerModal" tabindex="-1" role="dialog" aria-hidden="true">
    <div class="modal-dialog modal-lg" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="bannerModalTitle">Banner</h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div class="modal-body">
                <input type="hidden" id="bannerId" />
                <div class="form-row">
                    <div class="form-group col-md-6">
                        <label>V&#7883; tr&#237;</label>
                        <select class="form-control" id="position">
                            <option value="Hero">Hero</option>
                            <option value="Bottom">Bottom</option>
                        </select>
                    </div>
                    <div class="form-group col-md-6">
                        <label>Th&#7913; t&#7921;</label>
                        <input type="number" class="form-control" id="displayOrder" value="0" />
                    </div>
                </div>

                <div class="form-group">
                    <label>Ti&#234;u &#273;&#7873;</label>
                    <input type="text" class="form-control" id="title" />
                </div>

                <div class="form-group">
                    <label>Ti&#234;u &#273;&#7873; ph&#7909;</label>
                    <input type="text" class="form-control" id="subTitle" />
                </div>

                <div class="form-group">
                    <label>M&#244; t&#7843;</label>
                    <textarea class="form-control" id="description"></textarea>
                </div>

                <div class="form-group">
                    <label>Link URL</label>
                    <input type="text" class="form-control" id="linkUrl" placeholder="/Home/Shop" />
                </div>

                <div class="form-group">
                    <label>H&#236;nh &#7843;nh</label>
                    <input type="file" class="form-control" id="imageFile" accept="image/*" />
                    <small class="text-muted">Khi s&#7917;a, b&#7887; tr&#7889;ng n&#7871;u kh&#244;ng mu&#7889;n &#273;&#7893;i &#7843;nh.</small>
                </div>

                <div class="form-group form-check">
                    <input type="checkbox" class="form-check-input" id="isActive" checked>
                    <label class="form-check-label" for="isActive">Hi&#7875;n th&#7883; tr&#234;n trang ch&#7911;</label>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-dismiss="modal">&#272;&#243;ng</button>
                <button type="button" class="btn btn-primary" onclick="saveBanner()">L&#432;u</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        let bannerTable;

        function imageHtml(url) {
            if (!url) return '';
            return `<img src="${url}" style="width:120px;height:60px;object-fit:cover;" />`;
        }

        function openCreateModal() {
            $('#bannerModalTitle').text('Th\u00eam banner');
            $('#bannerId').val('');
            $('#position').val('Hero');
            $('#displayOrder').val(0);
            $('#title').val('');
            $('#subTitle').val('');
            $('#description').val('');
            $('#linkUrl').val('');
            $('#imageFile').val('');
            $('#isActive').prop('checked', true);
            $('#bannerModal').modal('show');
        }

        async function openEditModal(id) {
            const res = await fetch(`/api/admin/banners/${id}`);
            if (!res.ok) {
                alert('Kh\u00f4ng t\u1ea3i \u0111\u01b0\u1ee3c banner.');
                return;
            }

            const b = await res.json();
            $('#bannerModalTitle').text('S\u1eeda banner #' + b.id);
            $('#bannerId').val(b.id);
            $('#position').val(b.position || 'Hero');
            $('#displayOrder').val(b.displayOrder || 0);
            $('#title').val(b.title || '');
            $('#subTitle').val(b.subTitle || '');
            $('#description').val(b.description || '');
            $('#linkUrl').val(b.linkUrl || '');
            $('#imageFile').val('');
            $('#isActive').prop('checked', !!b.isActive);
            $('#bannerModal').modal('show');
        }

        async function saveBanner() {
            const id = $('#bannerId').val();
            const formData = new FormData();

            formData.append('position', $('#position').val());
            formData.append('displayOrder', $('#displayOrder').val() || 0);
            formData.append('title', $('#title').val());
            formData.append('subTitle', $('#subTitle').val());
            formData.append('description', $('#description').val());
            formData.append('linkUrl', $('#linkUrl').val());
            formData.append('isActive', $('#isActive').is(':checked'));

            const imageInput = document.getElementById('imageFile');
            if (imageInput.files.length > 0) {
                formData.append('imageFile', imageInput.files[0]);
            }

            const isEdit = !!id;
            const url = isEdit ? `/api/admin/banners/${id}` : '/api/admin/banners';
            const method = isEdit ? 'PUT' : 'POST';

            const res = await fetch(url, { method, body: formData });
            if (!res.ok) {
                const err = await res.text();
                alert('L\u01b0u banner th\u1ea5t b\u1ea1i: ' + err);
                return;
            }

            $('#bannerModal').modal('hide');
            await loadBanners();
        }

        async function deleteBanner(id) {
            if (!confirm('B\u1ea1n ch\u1eafc ch\u1eafn mu\u1ed1n x\u00f3a banner n\u00e0y?')) return;

            const res = await fetch(`/api/admin/banners/${id}`, { method: 'DELETE' });
            if (!res.ok) {
                alert('X\u00f3a th\u1ea5t b\u1ea1i.');
                return;
            }

            await loadBanners();
        }

        async function loadBanners() {
            const res = await fetch('/api/admin/banners');
            if (!res.ok) throw new Error('Kh\u00f4ng t\u1ea3i \u0111\u01b0\u1ee3c danh s\u00e1ch banner');
            const items = await res.json();

            if (bannerTable) {
                bannerTable.clear();
                bannerTable.rows.add(items).draw();
                return;
            }

            bannerTable = $('#bannerTable').DataTable({
                data: items,
                pageLength: 10,
                order: [[0, 'desc']],
                columns: [
                    { data: 'id' },
                    { data: 'position' },
                    { data: 'title', defaultContent: '' },
                    { data: 'imageUrl', render: d => imageHtml(d), orderable: false },
                    { data: 'displayOrder' },
                    {
                        data: 'isActive',
                        render: d => d ? '<span class="badge badge-success">B\u1eadt</span>' : '<span class="badge badge-secondary">T\u1eaft</span>'
                    },
                    {
                        data: null,
                        orderable: false,
                        render: function (d, t, row) {
                            return `
                                <button class="btn btn-warning btn-sm mr-1" onclick="openEditModal(${row.id})"><i class="fas fa-edit"></i></button>
                                <button class="btn btn-danger btn-sm" onclick="deleteBanner(${row.id})"><i class="fas fa-trash"></i></button>
                            `;
                        }
                    }
                ],
                language: {
                    search: 'T\u00ecm ki\u1ebfm:',
                    lengthMenu: 'Hi\u1ec3n th\u1ecb _MENU_ d\u00f2ng',
                    info: 'Hi\u1ec3n th\u1ecb _START_ \u0111\u1ebfn _END_ c\u1ee7a _TOTAL_ banner',
                    infoEmpty: 'Kh\u00f4ng c\u00f3 d\u1eef li\u1ec7u',
                    zeroRecords: 'Kh\u00f4ng t\u00ecm th\u1ea5y banner',
                    paginate: {
                        first: '\u0110\u1ea7u',
                        last: 'Cu\u1ed1i',
                        next: 'Sau',
                        previous: 'Tr\u01b0\u1edbc'
                    }
                }
            });
        }

        $(async function () {
            try {
                await loadBanners();
            } catch (e) {
                console.error(e);
                alert('Kh\u00f4ng th\u1ec3 t\u1ea3i danh s\u00e1ch banner.');
            }
        });
    </script>
}
