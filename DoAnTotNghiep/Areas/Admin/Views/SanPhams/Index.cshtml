@model IEnumerable<DoAnTotNghiep.Models.SanPham>

@{
    ViewData["Title"] = "Quản lý sản phẩm";
}

<div class="card shadow mb-4">
    <div class="card-header py-3 d-flex justify-content-between align-items-center">
        <h6 class="m-0 font-weight-bold text-primary">Danh sách sản phẩm</h6>
        <a asp-area="Admin" asp-controller="SanPhams" asp-action="Create" class="btn btn-primary btn-sm">Thêm mới</a>
    </div>

@section Scripts {
    <script>
        $(function () {
            $('#productTable').DataTable({
                pageLength: 10,
                order: [[0, 'desc']],
                columnDefs: [
                    { orderable: false, targets: [4, 5] }
                ],
                language: {
                    search: 'Tìm kiếm:',
                    lengthMenu: 'Hiển thị _MENU_ dòng',
                    info: 'Hiển thị _START_ đến _END_ của _TOTAL_ sản phẩm',
                    infoEmpty: 'Không có dữ liệu',
                    zeroRecords: 'Không tìm thấy sản phẩm',
                    paginate: {
                        first: 'Đầu',
                        last: 'Cuối',
                        next: 'Sau',
                        previous: 'Trước'
                    }
                }
            });
        });
    </script>
}
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-bordered" id="productTable" width="100%">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Tên sản phẩm</th>
                        <th>Giá</th>
                        <th>Danh mục</th>
                        <th>Ảnh</th>
                        <th>Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.MaSanPham</td>
                            <td>@item.TenSanPham</td>
                            <td>@item.GiaTien.ToString("N0") đ</td>
                            <td>@item.MaDanhMucNavigation?.TenDanhMuc</td>
                            <td>
                                @if (!string.IsNullOrWhiteSpace(item.HinhAnh))
                                {
                                    <img src="@item.HinhAnh" alt="@item.TenSanPham" style="width:60px;height:60px;object-fit:cover;" />
                                }
                            </td>
                            <td>
                                <a asp-area="Admin" asp-controller="SanPhams" asp-action="Edit" asp-route-id="@item.MaSanPham" class="btn btn-warning btn-sm">
                                    <i class="fas fa-edit"></i>
                                </a>
                                <a asp-area="Admin" asp-controller="SanPhams" asp-action="Delete" asp-route-id="@item.MaSanPham" class="btn btn-danger btn-sm">
                                    <i class="fas fa-trash"></i>
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>