@{
    ViewData["Title"] = "Quan ly san pham";
}

<div class="card shadow mb-4">
    <div class="card-header py-3 d-flex justify-content-between align-items-center">
        <h6 class="m-0 font-weight-bold text-primary">Danh s&#225;ch s&#7843;n ph&#7849;m (API)</h6>
        <a asp-area="Admin" asp-controller="SanPhams" asp-action="Create" class="btn btn-primary btn-sm">Th&#234;m m&#7899;i</a>
    </div>
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-bordered" id="productTable" width="100%">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>T&#234;n s&#7843;n ph&#7849;m</th>
                        <th>Gi&#225;</th>
                        <th>Danh m&#7909;c</th>
                        <th>&#7842;nh</th>
                        <th>Thao t&#225;c</th>
                    </tr>
                </thead>
                <tbody></tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function formatPrice(value) {
            const num = Number(value || 0);
            return num.toLocaleString('vi-VN') + ' \u0111';
        }

        function imageHtml(url, alt) {
            if (!url) return '';
            return `<img src="${url}" alt="${alt || ''}" style="width:60px;height:60px;object-fit:cover;" />`;
        }

        async function loadProducts() {
            const res = await fetch('/api/admin/products');
            if (!res.ok) throw new Error('Kh\u00F4ng t\u1EA3i \u0111\u01B0\u1EE3c danh s\u00E1ch s\u1EA3n ph\u1EA9m');
            return await res.json();
        }

        async function deleteProduct(id) {
            const ok = confirm('B\u1EA1n ch\u1EAFc ch\u1EAFn mu\u1ED1n x\u00F3a s\u1EA3n ph\u1EA9m n\u00E0y?');
            if (!ok) return;

            const res = await fetch(`/api/admin/products/${id}`, { method: 'DELETE' });
            if (!res.ok) {
                alert('X\u00F3a s\u1EA3n ph\u1EA9m th\u1EA5t b\u1EA1i.');
                return;
            }

            location.reload();
        }

        $(async function () {
            try {
                const products = await loadProducts();

                $('#productTable').DataTable({
                    data: products,
                    pageLength: 10,
                    order: [[0, 'desc']],
                    columns: [
                        { data: 'maSanPham' },
                        { data: 'tenSanPham' },
                        {
                            data: 'giaTien',
                            render: function (data) { return formatPrice(data); }
                        },
                        { data: 'tenDanhMuc', defaultContent: '' },
                        {
                            data: null,
                            orderable: false,
                            render: function (data, type, row) {
                                return imageHtml(row.hinhAnh, row.tenSanPham);
                            }
                        },
                        {
                            data: null,
                            orderable: false,
                            render: function (data, type, row) {
                                return `
                                    <a href="/Admin/SanPhams/Edit/${row.maSanPham}" class="btn btn-warning btn-sm mr-1"><i class="fas fa-edit"></i></a>
                                    <button class="btn btn-danger btn-sm" onclick="deleteProduct(${row.maSanPham})"><i class="fas fa-trash"></i></button>
                                `;
                            }
                        }
                    ],
                    language: {
                        search: 'T\u00ECm ki\u1EBFm:',
                        lengthMenu: 'Hi\u1EC3n th\u1ECB _MENU_ d\u00F2ng',
                        info: 'Hi\u1EC3n th\u1ECB _START_ \u0111\u1EBFn _END_ c\u1EE7a _TOTAL_ s\u1EA3n ph\u1EA9m',
                        infoEmpty: 'Kh\u00F4ng c\u00F3 d\u1EEF li\u1EC7u',
                        zeroRecords: 'Kh\u00F4ng t\u00ECm th\u1EA5y s\u1EA3n ph\u1EA9m',
                        paginate: {
                            first: '\u0110\u1EA7u',
                            last: 'Cu\u1ED1i',
                            next: 'Sau',
                            previous: 'Tr\u01B0\u1EDBc'
                        }
                    }
                });
            } catch (e) {
                console.error(e);
                alert('Kh\u00F4ng th\u1EC3 t\u1EA3i danh s\u00E1ch s\u1EA3n ph\u1EA9m t\u1EEB API admin.');
            }
        });
    </script>
}
