@model DoAnTotNghiep.Models.SanPham

@{
    ViewData["Title"] = "Thêm sản phẩm";
}

<h2 class="mb-4">Thêm sản phẩm</h2>

<form asp-area="Admin" asp-controller="SanPhams" asp-action="Create" method="post" enctype="multipart/form-data">
    @Html.AntiForgeryToken()

    <div class="form-group mb-3">
        <label asp-for="TenSanPham"></label>
        <input asp-for="TenSanPham" class="form-control" />
        <span asp-validation-for="TenSanPham" class="text-danger"></span>
    </div>

    <div class="form-group mb-3">
        <label asp-for="GiaTien"></label>
        <input asp-for="GiaTien" class="form-control" />
        <span asp-validation-for="GiaTien" class="text-danger"></span>
    </div>

    <div class="form-group mb-3">
        <label asp-for="MoTa"></label>
        <textarea asp-for="MoTa" class="form-control"></textarea>
        <span asp-validation-for="MoTa" class="text-danger"></span>
    </div>

    <div class="form-group mb-3">
        <label>Ảnh sản phẩm</label>
        <input type="file" name="imageFile" accept="image/*" class="form-control" />
    </div>

    <div class="form-group mb-3">
        <label asp-for="MaDanhMuc">Danh mục</label>
        <select asp-for="MaDanhMuc" asp-items="ViewBag.MaDanhMuc" class="form-control">
            <option value="">-- Chọn danh mục --</option>
        </select>
        <span asp-validation-for="MaDanhMuc" class="text-danger"></span>
    </div>

    <button type="submit" class="btn btn-primary">Lưu</button>
    <a asp-area="Admin" asp-controller="SanPhams" asp-action="Index" class="btn btn-secondary">Quay lại</a>
    </form>