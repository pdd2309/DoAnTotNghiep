@model DoAnTotNghiep.Models.SanPham

@{
    ViewData["Title"] = "Xóa sản phẩm";
}

<h2 class="mb-4 text-danger">Xóa sản phẩm</h2>

<div class="alert alert-warning">
    Bạn có chắc muốn xóa sản phẩm: <strong>@Model.TenSanPham</strong>?
</div>

<form asp-area="Admin" asp-controller="SanPhams" asp-action="Delete" method="post">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="MaSanPham" />

    <button type="submit" class="btn btn-danger">Xóa</button>
    <a asp-area="Admin" asp-controller="SanPhams" asp-action="Index" class="btn btn-secondary">Hủy</a>
</form>