@{
    ViewData["Title"] = "Quan ly danh muc";
}

<div class="card shadow mb-4">
    <div class="card-header py-3 d-flex justify-content-between align-items-center">
        <h6 class="m-0 font-weight-bold text-primary">Danh sach danh muc (API)</h6>
        <button type="button" class="btn btn-primary btn-sm" onclick="openCreateModal()">Them moi</button>
    </div>
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-bordered" id="categoryTable" width="100%" cellspacing="0">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Ten danh muc</th>
                        <th>Hinh anh</th>
                        <th>Thu tu</th>
                        <th>Trang chu</th>
                        <th>Thao tac</th>
                    </tr>
                </thead>
                <tbody></tbody>
            </table>
        </div>
    </div>
</div>

<div class="modal fade" id="categoryModal" tabindex="-1" role="dialog" aria-hidden="true">
    <div class="modal-dialog" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="categoryModalTitle">Danh muc</h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div class="modal-body">
                <input type="hidden" id="categoryId" />

                <div class="form-group">
                    <label>Ten danh muc</label>
                    <input type="text" class="form-control" id="tenDanhMuc" />
                </div>

                <div class="form-group">
                    <label>Link hinh (tuy chon)</label>
                    <input type="text" class="form-control" id="hinhAnh" placeholder="/img/categories/cat-1.jpg" />
                </div>

                <div class="form-group">
                    <label>Hoac upload hinh moi</label>
                    <input type="file" class="form-control" id="imageFile" accept="image/*" />
                </div>

                <div class="form-group">
                    <label>Thu tu hien thi (nho hon se hien truoc)</label>
                    <input type="number" class="form-control" id="thuTuHienThi" value="0" />
                </div>

                <div class="form-group form-check">
                    <input type="checkbox" class="form-check-input" id="isHienThiTrangChu" checked>
                    <label class="form-check-label" for="isHienThiTrangChu">Hien thi tren trang chu</label>
                </div>

                <div id="previewWrapper" class="text-center" style="display:none;">
                    <img id="previewImage" src="" style="max-width:100%;max-height:180px;object-fit:contain;" />
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-dismiss="modal">Dong</button>
                <button type="button" class="btn btn-primary" onclick="saveCategory()">Luu</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        let categoryTable;

        function imageCell(url) {
            if (!url) return '<span class="text-muted">No image</span>';
            return `<img src="${url}" style="width:90px;height:60px;object-fit:cover;" />`;
        }

        function showPreview(url) {
            if (!url) {
                $('#previewWrapper').hide();
                $('#previewImage').attr('src', '');
                return;
            }

            $('#previewImage').attr('src', url);
            $('#previewWrapper').show();
        }

        async function loadCategories() {
            const res = await fetch('/api/admin/categories');
            if (!res.ok) throw new Error('Cannot load categories');
            return await res.json();
        }

        function openCreateModal() {
            $('#categoryModalTitle').text('Them danh muc');
            $('#categoryId').val('');
            $('#tenDanhMuc').val('');
            $('#hinhAnh').val('');
            $('#imageFile').val('');
            $('#thuTuHienThi').val(0);
            $('#isHienThiTrangChu').prop('checked', true);
            showPreview('');
            $('#categoryModal').modal('show');
        }

        async function openEditModal(id) {
            const res = await fetch(`/api/admin/categories/${id}`);
            if (!res.ok) {
                alert('Khong tai duoc danh muc');
                return;
            }

            const item = await res.json();
            $('#categoryModalTitle').text('Sua danh muc #' + item.maDanhMuc);
            $('#categoryId').val(item.maDanhMuc);
            $('#tenDanhMuc').val(item.tenDanhMuc || '');
            $('#hinhAnh').val(item.hinhAnh || '');
            $('#imageFile').val('');
            $('#thuTuHienThi').val(item.thuTuHienThi || 0);
            $('#isHienThiTrangChu').prop('checked', !!item.isHienThiTrangChu);
            showPreview(item.hinhAnh || '');
            $('#categoryModal').modal('show');
        }

        async function saveCategory() {
            const id = $('#categoryId').val();
            const tenDanhMuc = ($('#tenDanhMuc').val() || '').trim();
            const hinhAnh = ($('#hinhAnh').val() || '').trim();
            const thuTuHienThi = parseInt($('#thuTuHienThi').val() || '0', 10);
            const isHienThiTrangChu = $('#isHienThiTrangChu').is(':checked');

            if (!tenDanhMuc) {
                alert('Vui long nhap ten danh muc.');
                return;
            }

            const formData = new FormData();
            formData.append('tenDanhMuc', tenDanhMuc);
            formData.append('hinhAnh', hinhAnh);
            formData.append('thuTuHienThi', isNaN(thuTuHienThi) ? 0 : thuTuHienThi);
            formData.append('isHienThiTrangChu', isHienThiTrangChu);

            const imageInput = document.getElementById('imageFile');
            if (imageInput.files.length > 0) {
                formData.append('imageFile', imageInput.files[0]);
            }

            const isEdit = !!id;
            const url = isEdit ? `/api/admin/categories/${id}` : '/api/admin/categories';
            const method = isEdit ? 'PUT' : 'POST';

            const res = await fetch(url, { method, body: formData });
            if (!res.ok) {
                const err = await res.text();
                alert('Luu that bai: ' + err);
                return;
            }

            $('#categoryModal').modal('hide');
            await bindCategoryTable();
        }

        async function deleteCategory(id) {
            const ok = confirm('Ban chac chan muon xoa danh muc nay?');
            if (!ok) return;

            const res = await fetch(`/api/admin/categories/${id}`, { method: 'DELETE' });
            if (!res.ok) {
                alert('Xoa that bai. Co the danh muc dang duoc su dung.');
                return;
            }

            await bindCategoryTable();
        }

        async function bindCategoryTable() {
            const categories = await loadCategories();

            if (categoryTable) {
                categoryTable.clear();
                categoryTable.rows.add(categories).draw();
                return;
            }

            categoryTable = $('#categoryTable').DataTable({
                data: categories,
                pageLength: 10,
                order: [[0, 'desc']],
                columns: [
                    { data: 'maDanhMuc' },
                    { data: 'tenDanhMuc' },
                    {
                        data: 'hinhAnh',
                        orderable: false,
                        render: function (d) { return imageCell(d); }
                    },
                    { data: 'thuTuHienThi' },
                    {
                        data: 'isHienThiTrangChu',
                        render: function (d) {
                            return d
                                ? '<span class="badge badge-success">Hien</span>'
                                : '<span class="badge badge-secondary">An</span>';
                        }
                    },
                    {
                        data: null,
                        orderable: false,
                        render: function (data, type, row) {
                            return `
                                <button class="btn btn-warning btn-sm mr-1" onclick="openEditModal(${row.maDanhMuc})"><i class="fas fa-edit"></i></button>
                                <button class="btn btn-danger btn-sm" onclick="deleteCategory(${row.maDanhMuc})"><i class="fas fa-trash"></i></button>
                            `;
                        }
                    }
                ],
                language: {
                    search: 'Tim kiem:',
                    lengthMenu: 'Hien thi _MENU_ dong',
                    info: 'Hien thi _START_ den _END_ cua _TOTAL_ danh muc',
                    infoEmpty: 'Khong co du lieu',
                    zeroRecords: 'Khong tim thay danh muc',
                    paginate: {
                        first: 'Dau',
                        last: 'Cuoi',
                        next: 'Sau',
                        previous: 'Truoc'
                    }
                }
            });
        }

        $('#hinhAnh').on('input', function () {
            const url = ($(this).val() || '').trim();
            showPreview(url);
        });

        $('#imageFile').on('change', function () {
            if (this.files && this.files[0]) {
                const tempUrl = URL.createObjectURL(this.files[0]);
                showPreview(tempUrl);
            }
        });

        $(async function () {
            try {
                await bindCategoryTable();
            } catch (e) {
                console.error(e);
                alert('Khong the tai danh sach danh muc.');
            }
        });
    </script>
}
