@model IEnumerable<DoAnTotNghiep.Models.DanhMuc>

@{
    ViewData["Title"] = "Quản lý Danh mục";
}

<div class="card shadow mb-4">
    <div class="card-header py-3 d-flex justify-content-between align-items-center">
        <h6 class="m-0 font-weight-bold text-primary lang" data-vi="Danh sách danh mục" data-en="Category List">Danh sách danh mục</h6>
        <a asp-area="Admin" asp-controller="DanhMucs" asp-action="Create" class="btn btn-primary btn-sm lang" data-vi="Thêm mới" data-en="Add New">Thêm mới</a>
    </div>

@section Scripts {
    <script>
        $(function () {
            $('#categoryTable').DataTable({
                pageLength: 10,
                order: [[0, 'desc']],
                columnDefs: [
                    { orderable: false, targets: [2] }
                ],
                language: {
                    search: 'Tìm kiếm:',
                    lengthMenu: 'Hiển thị _MENU_ dòng',
                    info: 'Hiển thị _START_ đến _END_ của _TOTAL_ danh mục',
                    infoEmpty: 'Không có dữ liệu',
                    zeroRecords: 'Không tìm thấy danh mục',
                    paginate: {
                        first: 'Đầu',
                        last: 'Cuối',
                        next: 'Sau',
                        previous: 'Trước'
                    }
                }
            });
        });
    </script>
}
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-bordered" id="categoryTable" width="100%" cellspacing="0">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th class="lang" data-vi="Tên danh mục" data-en="Category Name">Tên danh mục</th>
                        <th class="lang" data-vi="Thao tác" data-en="Actions">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.MaDanhMuc</td>
                            <td>@item.TenDanhMuc</td>
                            <td>
                                <a asp-area="Admin" asp-controller="DanhMucs" asp-action="Edit" asp-route-id="@item.MaDanhMuc" class="btn btn-warning btn-sm"><i class="fas fa-edit"></i></a>
                                <a asp-area="Admin" asp-controller="DanhMucs" asp-action="Delete" asp-route-id="@item.MaDanhMuc" class="btn btn-danger btn-sm"><i class="fas fa-trash"></i></a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>