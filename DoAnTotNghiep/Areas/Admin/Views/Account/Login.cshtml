@{
    Layout = null;
    ViewData["Title"] = "Admin Login";
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Đăng nhập Admin</title>
    <link href="/admin/vendor/fontawesome-free/css/all.min.css" rel="stylesheet" />
    <link href="/admin/css/sb-admin-2.min.css" rel="stylesheet" />
    <style>
        body.login-bg {
            min-height: 100vh;
            background: linear-gradient(rgba(0, 0, 0, 0.45), rgba(0, 0, 0, 0.45)), url('/img/admin-login-bg.jpg') center center / cover no-repeat fixed;
        }

        .login-card {
            backdrop-filter: blur(2px);
        }
    </style>
</head>
<body class="login-bg">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-xl-5 col-lg-6 col-md-8">
                <div class="card login-card o-hidden border-0 shadow-lg my-5">
                    <div class="card-body p-5">
                        <div class="text-center mb-4">
                            <h1 class="h4 text-gray-900">Đăng nhập quản trị</h1>
                        </div>

                        @if (ViewBag.Error != null)
                        {
                            <div class="alert alert-danger">@ViewBag.Error</div>
                        }

                        <form method="post" action="/Admin/Account/Login">
                            <div class="form-group">
                                <input name="username" class="form-control form-control-user" placeholder="Tên đăng nhập" required />
                            </div>
                            <div class="form-group">
                                <input name="password" type="password" class="form-control form-control-user" placeholder="Mật khẩu" required />
                            </div>
                            <button type="submit" class="btn btn-primary btn-user btn-block">Đăng nhập</button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</body>
</html>

